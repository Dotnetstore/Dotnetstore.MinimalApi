{
  "WebApi": {
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:7000"
      ],
      "AllowedMethods": [
        "GET",
        "POST",
        "PUT"
      ]
    },
    "Hsts": {
      "Preload": true,
      "IncludeSubDomains": true,
      "MaxAgeDays": 30
    },
    "HttpsRedirection": {
      "Development": {
        "RedirectStatusCode": 307,
        "HttpsPort": 7201
      },
      "Production": {
        "RedirectStatusCode": 308,
        "HttpsPort": 443
      }
    },
    "RateLimiting": {
      "RejectionStatusCode": 429,
      "RejectionMessage": "Too many requests. Please try again later.",
      "PartitionKeyFallback": "unknown",
      "GlobalPermitLimit": 50,
      "GlobalQueueLimit": 10,
      "GlobalWindowSeconds": 15,
      "ShortPermitLimit": 10,
      "ShortQueueLimit": 0,
      "ShortWindowSeconds": 15
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
